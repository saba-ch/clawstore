{
  "name": "clawstore",
  "version": "0.1.1",
  "description": "CLI for the ClawStore agent package registry",
  "repository": {
    "type": "git",
    "url": "https://github.com/saba-ch/clawstore.git"
  },
  "homepage": "https://github.com/saba-ch/clawstore#readme",
  "bugs": {
    "url": "https://github.com/saba-ch/clawstore/issues"
  },
  "type": "module",
  "bin": {
    "clawstore": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^13.1.0",
    "glob": "^13.0.6",
