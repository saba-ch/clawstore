    "semver": "^7.7.4",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@clawstore/schema": "workspace:*",
    "@clawstore/sdk": "workspace:*",
    "@clawstore/validator": "workspace:*",
    "@types/glob": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "@types/tar": "^7.0.87",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
