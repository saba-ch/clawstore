{
  "name": "clawstore",
  "version": "0.1.3",
  "description": "Clawstore — the app store for AI agents. Discover, install, and publish OpenClaw agents.",
  "keywords": [
    "openclaw",
    "ai-agents",
    "clawstore",
    "package-manager",
    "cli",
    "agent-store",
    "mcp",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/saba-ch/clawstore.git"
  },
  "homepage": "https://useclawstore.com",
  "bugs": {
    "url": "https://github.com/saba-ch/clawstore/issues"
  },
  "type": "module",
  "bin": {
    "clawstore": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^13.1.0",
    "glob": "^13.0.6",
    "open": "^11.0.0",
    "semver": "^7.7.4",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@clawstore/schema": "workspace:*",
    "@clawstore/sdk": "workspace:*",
    "@clawstore/validator": "workspace:*",
    "@types/glob": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "@types/tar": "^7.0.87",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
